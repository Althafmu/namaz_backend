# Django Secret Key - generate a unique 50+ character string
# SECURITY: Never commit the actual key to version control
SECRET_KEY=your-secret-key-here

# Debug mode - set to 'False' in production
DEBUG=True

# Allowed hosts - comma-separated list of valid hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL - PostgreSQL recommended for production
# Example: postgresql://user:password@localhost:5432/namaz
DATABASE_URL=

# Email Configuration (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@falah.app

# Set to 'False' to send real emails in production
FAKE_EMAIL_ENABLED=True

# CORS Allowed Origins - comma-separated list
# Example: http://localhost:3000,https://your-frontend.com
CORS_ALLOWED_ORIGINS=

# App Base URL - used for email links
APP_BASE_URL=http://localhost:8000

# Deployment environment ( Railway/Render)
# RENDER=1
# RAILWAY_ENVIRONMENT=1

# Security settings for production
# SECURE_HSTS_SECONDS=31536000
